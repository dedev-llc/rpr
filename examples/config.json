{
  "model": "claude-opus-4-6",
  "max_tokens": 16000,
  "max_diff_chars": 120000,
  "skip_patterns": [
    "*.lock",
    "*.g.dart",
    "*.freezed.dart",
    "*.gen.dart",
    "*.mocks.dart",
    "pubspec.lock",
    "package-lock.json",
    "yarn.lock",
    "Podfile.lock",
    "*.pbxproj",
    "*.min.js",
    "*.min.css",
    "*.map",
    "ios/Runner.xcodeproj/*",
    "android/app/src/main/res/*",
    ".dart_tool/*"
  ]
}
